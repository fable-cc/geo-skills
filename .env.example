# GEO Skills 配置文件
# 复制此文件为 .env 并替换实际值
#   cp .env.example .env

# ── API 密钥 ──
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxx

# ── API 端点（使用代理时可修改）──
OPENAI_BASE_URL=https://api.openai.com/v1

# ── 默认模型 ──
LLM_MODEL=gpt-4o-mini

# ── 默认平台 ──
GEO_DEFAULT_PLATFORM=zhihu

# ── 默认品牌实体 ──
GEO_DEFAULT_BRAND=景一·寓言城堡

# ── API 超时（秒）──
GEO_TIMEOUT=180
